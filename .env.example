# Database URLs (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql://<username>:<password>@localhost:5432/<database_name>
COCOINDEX_DATABASE_URL=postgresql://<username>:<password>@localhost:5432/<database_name>

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
